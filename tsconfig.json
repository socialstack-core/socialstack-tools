{
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"rootDir": "./src",
		"outDir": "./dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": false,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"lib": [
			"es2022"
		]
	},
	"include": [
		"src/**/*"
	]
}